# Site Configuration
NEXT_PUBLIC_SITE_URL=https://lanework.ai

# Sanity CMS (shared with Rapid Relay: same project/dataset holds the research content)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_API_VERSION=2025-12-30
SANITY_DEPLOYMENT_APP_ID=
SANITY_API_WRITE_TOKEN=
# Supabase Database — Lanework's OWN Supabase project (separate from Rapid Relay).
# Run `npx prisma db push` against it once to create the tables.
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend Email
RESEND_API_KEY=
# Email address to send from (must be verified in Resend)
FROM_EMAIL=
# Admin email to receive notifications
ADMIN_EMAIL=

# Newsletter API Key for Sanity Studio
SANITY_STUDIO_NEWSLETTER_API_KEY=

# Google Verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# Analytics pixels (Phase 2). Each is optional and the corresponding pixel
# loader stays dormant when its ID is unset.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=                 # e.g. G-ABC123XYZ
GA4_API_SECRET=                                  # server-side MP secret (GA4 admin > Data Streams)
NEXT_PUBLIC_META_PIXEL_ID=                       # Facebook/Meta numeric pixel ID
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=                 # LinkedIn Insight Tag partner ID
NEXT_PUBLIC_LINKEDIN_LEAD_CONVERSION_ID=         # LinkedIn conversion ID for lead form fills
NEXT_PUBLIC_LINKEDIN_DOWNLOAD_CONVERSION_ID=     # LinkedIn conversion ID for gated downloads

# Drip nurture cron (Phase 2). CRON_SECRET protects /api/cron/drip. Set a strong
# random value in production env vars. ALLOW_DRIP_TIME_SHIM is local-test-only.
CRON_SECRET=
ALLOW_DRIP_TIME_SHIM=
SALES_REPLY_TO=                                  # optional, falls back to ADMIN_EMAIL

# Resend webhook (Phase 2 deliverability hygiene). Signing secret from
# https://resend.com/webhooks > endpoint > Signing Secret (starts with whsec_).
# When unset, /api/webhooks/resend returns 503 — safer than accepting unsigned
# payloads. Set before pointing Resend at the live endpoint.
RESEND_WEBHOOK_SECRET=

# Lanework is a public standalone site: no /admin backend and no Basic-Auth gate
# (both lived in the Rapid Relay app). Optional override for the URL used in
# Lanework transactional emails; defaults to https://lanework.ai when unset.
LANEWORK_SITE_URL=

# PostHog product analytics. Init no-ops cleanly when the key is unset.
# KEY: PostHog project "Project API Key" (starts with phc_).
# HOST: ingestion host — keep the US Cloud default below.
# DASHBOARD_URL: legacy iframe embed url (the /admin/analytics page now renders
#   native charts from the Query API instead; leave blank).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_DASHBOARD_URL=

# Server-side read access for the native /admin/analytics dashboard (NOT public —
# no NEXT_PUBLIC_ prefix). Must be set in the runtime environment (Netlify site env)
# as well as locally, because the page queries PostHog at request time.
# PERSONAL_API_KEY: a PostHog Personal API Key with read/query scope.
# PROJECT_ID: the numeric project id (Settings > Project).
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Server-only salt used to hash client IPs for contact-form anti-spam rate
# limiting (any long random string; raw IPs are never stored). Set in Netlify env.
RATE_LIMIT_SALT=